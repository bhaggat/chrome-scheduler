# Chrome Web Store API Credentials
# Get these from: https://developer.chrome.com/docs/webstore/using_webstore_api/

# Your extension ID from Chrome Web Store
EXTENSION_ID=peimippheccjbhianpahacphickkbbjl

# OAuth2 Client ID
CHROME_CLIENT_ID=your_client_id_here

# OAuth2 Client Secret
CHROME_CLIENT_SECRET=your_client_secret_here

# OAuth2 Refresh Token
CHROME_REFRESH_TOKEN=your_refresh_token_here

# Publish target: 'default' (public) or 'trustedTesters' (beta)
PUBLISH_TARGET=default
